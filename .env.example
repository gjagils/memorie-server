# Memorie server configuration
#
# Set these in Portainer's stack environment variables (or in a local .env
# file when running with `docker compose` directly).

# Host port mapped to the container. The container-internal port is fixed at
# 8090 (set in docker-compose.yml). Pick any free port on your Synology.
MEMORIE_HOST_PORT=8090

# Immich integration (ADR-0002)
# URL where Immich is reachable from the Memorie container.
# Examples:
#   - http://immich-server:2283       (when on a shared Docker network)
#   - http://host.docker.internal:2283 (Synology host networking)
IMMICH_URL=http://immich-server:2283

# Immich API key for read access. Create in Immich web UI:
#   Account Settings → API Keys → New API Key (read scope)
IMMICH_API_KEY=
